# ============================================================
# Crate Vote — Environment Variables
# Copy to .env.local for local dev. Set the REQUIRED ones in
# Vercel → Project → Settings → Environment Variables for prod.
# Never commit real secrets. These are placeholders only.
# ============================================================

# ---------- REQUIRED: Data store ----------
# Upstash Redis — backs ALL song/vote/karma storage. Without it the app
# returns 503 (fails closed) instead of running with no persistence.
# Get from https://console.upstash.com/ or link Vercel KV.
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
# Alternative names if using Vercel's managed KV (either pair works):
# KV_REST_API_URL=your_vercel_kv_url
# KV_REST_API_TOKEN=your_vercel_kv_token

# ---------- REQUIRED: Admin access ----------
# Master key for the /admin panel and all admin API actions. There is NO
# fallback — if this is unset, admin login is disabled (fails closed).
# Use a long, random value. Do NOT ship the placeholder below.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# ---------- REQUIRED: Voter identity signing ----------
# Secret used to HMAC-sign the anonymous voter cookie that prevents vote
# farming. If unset it falls back to ADMIN_PASSWORD (works, but then rotating
# the admin password logs every voter out). Set a separate long random value.
VOTER_SECRET=change-me-to-a-different-long-random-string

# ---------- REQUIRED: Spotify (song search) ----------
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ---------- OPTIONAL: YouTube music-video previews ----------
# Get an API key at https://console.cloud.google.com/ (enable YouTube Data API v3).
# If unset, video previews are simply unavailable — the app still runs.
YOUTUBE_API_KEY=your_youtube_api_key_here

# ---------- OPTIONAL: Twitch bot integration ----------
# Only needed if you run the Twitch chat bot. The live Twitch EMBED on the
# main panel does NOT need these. Safe to leave unset.
TWITCH_CHANNEL=your_twitch_channel
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_OAUTH_TOKEN=oauth:your_token_here
TWITCH_BOT_SECRET=generate-a-random-secret-here
CRATE_VOTE_API_URL=https://your-app.vercel.app

# ---------- OPTIONAL: NextAuth (only if auth flows are enabled) ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# ---------- OPTIONAL: Branding / SEO ----------
NEXT_PUBLIC_APP_NAME=Crate Hackers
NEXT_PUBLIC_BASE_URL=http://localhost:3000
